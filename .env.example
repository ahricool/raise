# ===================================
# Daily Stock Analysis - Environment Template
# ===================================
# Usage:
#   cp .env.example .env
#   Edit secrets and stock list before running locally or with Docker Compose.

# ===================================
# 1. Runtime / Web service
# ===================================
TZ=Asia/Shanghai
WEBUI_HOST=0.0.0.0
API_PORT=8000
LOG_DIR=./logs
LOG_LEVEL=INFO
MAX_WORKERS=3
ADMIN_AUTH_ENABLED=false
TRUST_X_FORWARDED_FOR=false

# ===================================
# 2. Database / PostgreSQL
# ===================================
# Docker Compose uses the POSTGRES_* values for the postgres service.
# DATABASE_URL is consumed by the Python application through SQLAlchemy.
POSTGRES_VERSION=16-alpine
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=daily_stock_analysis
POSTGRES_USER=dsa
POSTGRES_PASSWORD=change_me_to_a_strong_password
DATABASE_URL=postgresql+psycopg2://dsa:change_me_to_a_strong_password@postgres:5432/daily_stock_analysis

# Legacy local/desktop fallback. Used only when DATABASE_URL is empty.
DATABASE_PATH=./data/stock_analysis.db
SQLITE_WAL_ENABLED=true
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_WRITE_RETRY_MAX=3
SQLITE_WRITE_RETRY_BASE_DELAY=0.1

# ===================================
# 3. Stock universe / scheduling
# ===================================
STOCK_LIST=600519,000001,AAPL
MARKET_REVIEW_ENABLED=true
MARKET_REVIEW_REGION=cn
TRADING_DAY_CHECK_ENABLED=true
SCHEDULE_ENABLED=false
SCHEDULE_TIME=18:00
RUN_IMMEDIATELY=false

# ===================================
# 4. LLM providers
# ===================================
# Pick one primary model and fill in the matching provider key/base URL.
LITELLM_MODEL=
LLM_CHANNELS=
LLM_FALLBACK_MODELS=
OPENAI_API_KEY=
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_API_BASE=
VISION_MODEL=

# ===================================
# 5. Data providers / search
# ===================================
TUSHARE_TOKEN=
LONGPORT_APP_KEY=
LONGPORT_APP_SECRET=
LONGPORT_ACCESS_TOKEN=
TAVILY_API_KEY=
SERPAPI_API_KEY=
REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em

# ===================================
# 6. Report generation
# ===================================
REPORT_TYPE=simple
REPORT_LANGUAGE=zh
REPORT_SUMMARY_ONLY=false
REPORT_TEMPLATES_DIR=templates
REPORT_RENDERER_ENABLED=false
REPORT_INTEGRITY_ENABLED=true
REPORT_INTEGRITY_RETRY=1
REPORT_HISTORY_COMPARE_N=0
SAVE_CONTEXT_SNAPSHOT=true

# ===================================
# 7. Notifications
# ===================================
SINGLE_STOCK_NOTIFY=false
MERGE_EMAIL_NOTIFICATION=false
NOTIFICATION_REPORT_CHANNELS=
NOTIFICATION_ALERT_CHANNELS=
NOTIFICATION_SYSTEM_ERROR_CHANNELS=
NOTIFICATION_DEDUP_TTL_SECONDS=0
NOTIFICATION_COOLDOWN_SECONDS=0
NOTIFICATION_QUIET_HOURS=
NOTIFICATION_TIMEZONE=
NOTIFICATION_MIN_SEVERITY=
NOTIFICATION_DAILY_DIGEST_ENABLED=false

# Email
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=

# Feishu / WeCom / DingTalk / Telegram / Discord / Slack / custom webhooks
FEISHU_WEBHOOK_URL=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_MAX_BYTES=20000
WECHAT_WEBHOOK_URL=
WECHAT_MAX_BYTES=4000
WECHAT_MSG_TYPE=markdown
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
DISCORD_MAIN_CHANNEL_ID=
DISCORD_MAX_WORDS=2000
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
CUSTOM_WEBHOOK_URL=
PUSHPLUS_TOKEN=
SERVERCHAN3_SENDKEY=

# ===================================
# 8. Markdown-to-image / rendering
# ===================================
MARKDOWN_TO_IMAGE_CHANNELS=
MARKDOWN_TO_IMAGE_MAX_CHARS=15000
MD2IMG_ENGINE=wkhtmltoimage
